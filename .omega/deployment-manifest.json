{
  "version": 1,
  "routes": [
    {
      "source": "^/_next/static/.*$",
      "target": {
        "kind": "static",
        "cacheControl": "public, max-age=31536000, immutable"
      },
      "fallback": {
        "kind": "static"
      }
    },
    {
      "source": "^/_next/image$",
      "target": {
        "kind": "imageOptimization"
      },
      "fallback": {
        "kind": "compute",
        "computeName": "default"
      }
    },
    {
      "source": "^(?:\\/_global-error)\\/$",
      "target": {
        "kind": "redirect",
        "statusCode": 308,
        "targetUri": "/_global-error"
      },
      "fallback": {
        "kind": "static"
      }
    },
    {
      "source": "^(?:\\/_global-error)(?:\\/$)?$",
      "target": {
        "kind": "compute",
        "computeName": "default"
      },
      "fallback": {
        "kind": "static"
      }
    },
    {
      "source": "^(?:\\/_not-found)\\/$",
      "target": {
        "kind": "redirect",
        "statusCode": 308,
        "targetUri": "/_not-found"
      },
      "fallback": {
        "kind": "static"
      }
    },
    {
      "source": "^(?:\\/_not-found)(?:\\/$)?$",
      "target": {
        "kind": "compute",
        "computeName": "default"
      },
      "fallback": {
        "kind": "static"
      }
    },
    {
      "source": "^(?:\\/about)\\/$",
      "target": {
        "kind": "redirect",
        "statusCode": 308,
        "targetUri": "/about"
      },
      "fallback": {
        "kind": "static"
      }
    },
    {
      "source": "^(?:\\/about)(?:\\/$)?$",
      "target": {
        "kind": "static",
        "cacheControl": "public, max-age=3600"
      },
      "fallback": {
        "kind": "compute",
        "computeName": "default"
      }
    },
    {
      "source": "^(?:\\/api\\/hello)(?:\\/$)?$",
      "target": {
        "kind": "compute",
        "computeName": "default"
      },
      "fallback": {
        "kind": "static"
      }
    },
    {
      "source": "^(?:\\/api\\/users)(?:\\/$)?$",
      "target": {
        "kind": "compute",
        "computeName": "default"
      },
      "fallback": {
        "kind": "static"
      }
    },
    {
      "source": "^(?:\\/)\\/$",
      "target": {
        "kind": "redirect",
        "statusCode": 308,
        "targetUri": "/"
      },
      "fallback": {
        "kind": "static"
      }
    },
    {
      "source": "^(?:\\/)(?:\\/$)?$",
      "target": {
        "kind": "static",
        "cacheControl": "public, max-age=3600"
      },
      "fallback": {
        "kind": "compute",
        "computeName": "default"
      }
    },
    {
      "source": "^/404\\.html$",
      "target": {
        "kind": "static"
      },
      "statusCode": 404,
      "fallback": {
        "kind": "compute",
        "computeName": "default"
      }
    },
    {
      "source": "^/500\\.html$",
      "target": {
        "kind": "static"
      },
      "statusCode": 500,
      "fallback": {
        "kind": "compute",
        "computeName": "default"
      }
    },
    {
      "source": "^/.*$",
      "target": {
        "kind": "static",
        "cacheControl": "public, max-age=3600"
      },
      "fallback": {
        "kind": "compute",
        "computeName": "default"
      }
    }
  ],
  "compute": {
    "default": {
      "runtime": "NodeJs-22.x",
      "directory": "compute/default",
      "entrypoint": "index.js"
    }
  },
  "staticAssets": "static",
  "imageSettings": {
    "sizes": [
      32,
      48,
      64,
      96,
      128,
      256,
      384,
      640,
      750,
      828,
      1080,
      1200,
      1920,
      2048,
      3840
    ],
    "domains": [],
    "remotePatterns": [],
    "formats": [
      "image/webp"
    ],
    "minimumCacheTTL": 14400,
    "dangerouslyAllowSVG": false
  }
}